# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgres://medusa_user:medusa_pass@localhost:5432/medusa_backend

# ─── Medusa Core ────────────────────────────────────────────
MEDUSA_ADMIN_ONBOARDING_TYPE=default
STORE_CORS=http://localhost:8000,http://localhost:7001
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
COOKIE_SECRET=your-super-secret-cookie-key-change-in-production

# ─── Redis (optional, recommended for production) ──────────
# REDIS_URL=redis://localhost:6379

# ─── Razorpay Payment Gateway ──────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_ACCOUNT=your_razorpay_account_id

# ─── Shiprocket Shipping ───────────────────────────────────
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_CHANNEL_ID=your_shiprocket_channel_id
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_TOKEN=your_shiprocket_webhook_token

# ─── Node Environment ──────────────────────────────────────
NODE_ENV=development
